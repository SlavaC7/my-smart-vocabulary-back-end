# ---- Build stage ----
FROM node:20-alpine AS builder

WORKDIR /app

COPY package*.json ./
RUN npm install --frozen-lockfile

COPY . .
RUN npm run build

# ---- Run stage ----
FROM node:20-alpine AS runner

WORKDIR /app

# Только нужные файлы
COPY package*.json ./
RUN npm install --omit=dev --frozen-lockfile

COPY --from=builder /app/dist ./dist

CMD ["node", "dist/main.js"]
